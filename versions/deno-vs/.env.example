# Turso database credentials
# For local dev, you can use a local SQLite file: file:./sapling.db
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# JWT secret for signing auth tokens (generate a strong random string)
AUTH_JWT_SECRET=change-me-to-a-strong-random-secret

# Default LLM model when no chat-level or per-message override is set
# Format: provider/model-name (e.g. anthropic/claude-sonnet-4-5, openai/gpt-4o)
SAPLING_DEFAULT_MODEL=anthropic/claude-sonnet-4-5
