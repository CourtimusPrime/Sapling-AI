{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "lint": "./node_modules/.bin/biome check .",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "db:generate": "node ./node_modules/.bin/drizzle-kit generate",
    "db:migrate": "deno run -A db/migrate.ts"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "exclude": ["**/_fresh/*", "drizzle.config.ts"],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "hono": "npm:hono@^4",
    "drizzle-orm": "npm:drizzle-orm@^0.44.0",
    "@libsql/client": "npm:@libsql/client@^0.14.0",
    "@libsql/client/node": "npm:@libsql/client@^0.14.0/node",
    "drizzle-kit": "npm:drizzle-kit@^0.30.0",
    "unocss": "npm:unocss@^0.65.3",
    "unocss/vite": "npm:unocss@^0.65.3/vite",
    "@unocss/preset-wind": "npm:@unocss/preset-wind@^0.65.3",
    "@biomejs/biome": "npm:@biomejs/biome@^1.9.4",
    "zod": "npm:zod@^3",
    "jose": "npm:jose@^5",
    "d3-hierarchy": "npm:d3-hierarchy@^3",
    "@tanstack/store": "npm:@tanstack/store@^0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
